# RANTAS Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=phishtrack
POSTGRES_PASSWORD=change-this-in-production
POSTGRES_DB=phishtrack

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# Application Settings
# ============================================
DEBUG=false
SECRET_KEY=change-this-secret-key-in-production-use-openssl-rand-hex-32
WEBHOOK_SECRET=change-this-secret-in-production

# Session timeout in minutes (5-1440)
SESSION_TIMEOUT_MINUTES=30

# Base URL for the application
BASE_URL=http://localhost:8000

# CORS Origins (comma-separated or JSON array)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000"]

# ============================================
# SMTP Email Configuration (fallback)
# ============================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=abuse@phishtrack.local
SMTP_FROM_NAME=PhishTrack Abuse Reporting
SMTP_USE_TLS=true

# ============================================
# Microsoft Graph API (alternative to SMTP)
# ============================================
GRAPH_ENABLED=false
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_FROM_EMAIL=

# ============================================
# Browserless Screenshot Service
# ============================================
BROWSERLESS_API_KEY=
BROWSERLESS_ENDPOINT=https://connected.browserless.io
BROWSERLESS_VIEWPORT_WIDTH=1440
BROWSERLESS_VIEWPORT_HEIGHT=900
BROWSERLESS_FULL_PAGE=true
BROWSERLESS_VERIFY_SSL=false

# ============================================
# XARF (eXtended Abuse Reporting Format)
# ============================================
XARF_REPORTER_ORG=PhishTrack
XARF_REPORTER_CONTACT=abuse@yourdomain.com
XARF_REPORTER_DOMAIN=yourdomain.com
XARF_STORAGE_PATH=./xarf_reports

# ============================================
# Microsoft Teams Webhook
# ============================================
TEAMS_WEBHOOK_URL=

# ============================================
# Hunting (CertStream/Typosquat Detection)
# ============================================
HUNTING_MIN_SCORE=50
HUNTING_ALERT_SCORE=80
HUNTING_RETENTION_DAYS=90
RAW_LOG_RETENTION_DAYS=3

# Brand impacted (comma-separated or JSON array)
BRAND_IMPACTED=["Example Corp","Test Corp","Corporate Website","Subsidiary","Others"]

# ============================================
# CT Log / Sunlight Configuration
# ============================================
SUNLIGHT_ENABLED=true
SUNLIGHT_ENTRIES_PER_LOG=50
# Comma-separated CT log URLs
SUNLIGHT_PUBLIC_LOGS=https://ct.googleapis.com/logs/us1/argon2026h1/,https://ct.googleapis.com/logs/us1/argon2026h2/,https://ct.cloudflare.com/logs/nimbus2026/

# ============================================
# Monitoring
# ============================================
DEFAULT_MONITOR_INTERVAL=21600

# ============================================
# Port Configuration (for docker-compose)
# ============================================
BACKEND_PORT=9000
FRONTEND_PORT=3001
FLOWER_PORT=5557

# ============================================
# Resource Limits (for docker-compose)
# ============================================
DB_CPU_LIMIT=1.0
DB_MEM_LIMIT=512M
DB_CPU_RESERVATION=0.25
DB_MEM_RESERVATION=128M

REDIS_CPU_LIMIT=0.5
REDIS_MEM_LIMIT=256M
REDIS_CPU_RESERVATION=0.1
REDIS_MEM_RESERVATION=64M

BACKEND_CPU_LIMIT=1.0
BACKEND_MEM_LIMIT=1G
BACKEND_CPU_RESERVATION=0.25
BACKEND_MEM_RESERVATION=256M

CELERY_CPU_LIMIT=1.0
CELERY_MEM_LIMIT=512M
CELERY_CPU_RESERVATION=0.25
CELERY_MEM_RESERVATION=128M

BEAT_CPU_LIMIT=0.5
BEAT_MEM_LIMIT=256M
BEAT_CPU_RESERVATION=0.1
BEAT_MEM_RESERVATION=64M

FLOWER_CPU_LIMIT=0.5
FLOWER_MEM_LIMIT=256M
FLOWER_CPU_RESERVATION=0.1
FLOWER_MEM_RESERVATION=64M

FRONTEND_CPU_LIMIT=0.5
FRONTEND_MEM_LIMIT=512M
FRONTEND_CPU_RESERVATION=0.1
FRONTEND_MEM_RESERVATION=128M

# ============================================
# Frontend (Next.js) - for local development
# ============================================
# NOTE: NEXT_PUBLIC_API_URL is baked into the JS bundle at build time
# To change it, rebuild the frontend image with --build-arg
NEXT_PUBLIC_API_URL=http://localhost:9000/api
NODE_ENV=production

# Frontend features (optional)
NEXT_PUBLIC_ENABLE_TAB_SYNC=true
NEXT_PUBLIC_ENABLE_ACTIVITY_TIMEOUT=true
NEXT_PUBLIC_ENABLE_TOKEN_REFRESH=true

# ============================================
# Image Version (for docker-compose.ghcr.yml)
# ============================================
IMAGE_VERSION=latest
