# RANTAS Backend - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
# PostgreSQL (production)
DATABASE_URL=postgresql+asyncpg://phishtrack:password@localhost:5432/phishtrack

# SQLite (local development only)
# DATABASE_URL=sqlite+aiosqlite:///./phishtrack.db

# ============================================
# Redis / Celery Configuration
# ============================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# Security
# ============================================
# Generate a secure key: openssl rand -hex 32
SECRET_KEY=change-this-secret-key-in-production-use-openssl-rand-hex-32
WEBHOOK_SECRET=change-this-webhook-secret-in-production

# Default admin password (used when creating initial admin user)
# If not set, a secure random password is generated and printed to console
# Generate one: openssl rand -base64 24
DEFAULT_ADMIN_PASSWORD=

# Session timeout in minutes (5-1440)
SESSION_TIMEOUT_MINUTES=30

# ============================================
# Application Settings
# ============================================
DEBUG=true
BASE_URL=http://localhost:8000

# CORS Origins (JSON array or comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000"]

# Brand impacted (JSON array or comma-separated)
BRAND_IMPACTED=["Example Corp","Test Corp","Corporate Website","Subsidiary","Others"]

# ============================================
# SMTP Email Configuration (fallback)
# ============================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=abuse@example.com
SMTP_FROM_NAME=PhishTrack Abuse Reporting
SMTP_USE_TLS=true

# ============================================
# Microsoft Graph API (alternative to SMTP)
# Set SMTP_ENABLED=false and GRAPH_ENABLED=true to use Graph API
# ============================================
GRAPH_ENABLED=false
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_FROM_EMAIL=

# ============================================
# Browserless Screenshot Service
# ============================================
BROWSERLESS_API_KEY=
BROWSERLESS_ENDPOINT=https://connected.browserless.io
BROWSERLESS_VIEWPORT_WIDTH=1440
BROWSERLESS_VIEWPORT_HEIGHT=900
BROWSERLESS_FULL_PAGE=true
BROWSERLESS_VERIFY_SSL=false

# ============================================
# XARF (eXtended Abuse Reporting Format)
# ============================================
XARF_REPORTER_ORG=PhishTrack
XARF_REPORTER_CONTACT=abuse@yourdomain.com
XARF_REPORTER_DOMAIN=yourdomain.com
XARF_STORAGE_PATH=./xarf_reports

# ============================================
# Evidence Storage
# ============================================
EVIDENCE_STORAGE_PATH=./evidence

# ============================================
# Microsoft Teams Webhook (optional)
# ============================================
TEAMS_WEBHOOK_URL=

# ============================================
# Hunting (CertStream/Typosquat Detection)
# ============================================
HUNTING_MIN_SCORE=50
HUNTING_ALERT_SCORE=80
HUNTING_RETENTION_DAYS=90
RAW_LOG_RETENTION_DAYS=3

# ============================================
# CT Log / Sunlight Configuration
# ============================================
SUNLIGHT_ENABLED=true
SUNLIGHT_ENTRIES_PER_LOG=50
SUNLIGHT_PUBLIC_LOGS=https://ct.googleapis.com/logs/us1/argon2026h1/,https://ct.googleapis.com/logs/us1/argon2026h2/,https://ct.cloudflare.com/logs/nimbus2026/

# ============================================
# Monitoring
# ============================================
DEFAULT_MONITOR_INTERVAL=21600

# ============================================
# Redis Direct Access (for services)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# Ollama AI Configuration (for AI-powered analysis)
# ============================================
# Enable AI-powered phishing detection using Ollama Cloud or self-hosted Ollama
# Set OLLAMA_ENABLED=true to enable AI analysis on public submission page
# Recommend to use GLM-5 (You can use other cloud models)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_API_KEY=your-ollama-api-key-here
OLLAMA_MODEL=glm-5
OLLAMA_TIMEOUT=60

# ============================================
# Timezone
# ============================================
TIMEZONE=Asia/Jakarta
