# RANTAS Frontend - Environment Configuration
# Copy this file to .env.local for local development
#
# Note: NEXT_PUBLIC_* variables are exposed to the browser
# Do not add secrets or sensitive data here

# ============================================
# API Configuration
# ============================================
# Backend API URL (baked into JS bundle at build time)
NEXT_PUBLIC_API_URL=http://localhost:9000/api

# ============================================
# Feature Flags
# ============================================
# Enable tab sync across browser tabs (default: true)
NEXT_PUBLIC_ENABLE_TAB_SYNC=true

# Enable activity timeout (logout on inactivity) (default: true)
NEXT_PUBLIC_ENABLE_ACTIVITY_TIMEOUT=true

# Enable automatic token refresh (default: true)
NEXT_PUBLIC_ENABLE_TOKEN_REFRESH=true

# ============================================
# Build Configuration (for Docker builds)
# ============================================
# These are used at build time, not runtime
# NEXT_PUBLIC_API_URL must be passed as --build-arg
